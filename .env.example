# GYconnect Environment Variables
# Copy this to .env.local and fill in your values

TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here
SUPPORT_CHANNEL=https://t.me/your_support_channel
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your_turso_token_here
CELO_USDT_WALLET=0xYourCeloWalletAddress
SOLANA_WALLET=YourSolanaWalletAddress
ALCHEMY_CELO_KEY=your_alchemy_celo_key
ALCHEMY_CELO_URL=https://celo-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_SOLANA_KEY=your_alchemy_solana_key
ALCHEMY_SOLANA_URL=https://solana-mainnet.g.alchemy.com/v2/your_key
